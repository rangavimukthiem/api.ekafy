# ─── EKAFY Environment Configuration ─────────────────────────────────────────
# Copy this to .env and fill in real values. Never commit .env to git.

# Core Django
DEBUG=False
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_50_CHARS
ALLOWED_HOSTS=api.ekafy.com,dashboard.ekafy.com,127.0.0.1,localhost

# Database (PostgreSQL)
DB_NAME=ekafy
DB_USER=ekafy
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# Cache (Redis)
REDIS_URL=redis://127.0.0.1:6379/1

# JWT Settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS — add your frontend origins
CORS_ALLOWED_ORIGINS=https://dashboard.ekafy.com

# Timezone
TIME_ZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_FILE=/srv/ekafy/logs/django.log

# Security — set True once SSL is active
FORCE_HTTPS=False

# Dashboard monitoring (lines to tail)
MONITORING_LOG_LINES=100
